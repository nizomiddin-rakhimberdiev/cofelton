# Telegram bot orqali formalar yuboriladi
# Bot yaratish: @BotFather da /newbot
# Chat ID olish: @userinfobot ga /start

VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
# Bir nechta admin uchun vergul bilan ajratilgan:
VITE_TELEGRAM_CHAT_ID=726130790, 5664135803

# Supabase (maxsulotlar, sharhlar, arizalar saqlash uchun)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Admin panel credentiallari (/admin sahifasi uchun)
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=change_this_strong_password
